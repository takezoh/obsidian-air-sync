{
	"name": "obsidian-air-sync",
	"version": "0.1.37",
	"description": "Sync your vault with cloud storage (Google Drive, OneDrive, Dropbox).",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint --max-warnings 0 .",
		"lint:bot-repro": "node lint-bot-repro.mjs",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"test:e2e": "vitest run --config e2e/vitest.e2e.config.ts",
		"test:e2e:google": "vitest run --config e2e/vitest.e2e.config.ts googledrive",
		"test:e2e:dropbox": "vitest run --config e2e/vitest.e2e.config.ts dropbox",
		"test:e2e:onedrive": "vitest run --config e2e/vitest.e2e.config.ts onedrive",
		"e2e:bootstrap": "node e2e/run-bootstrap.mjs"
	},
	"keywords": [],
	"license": "MIT",
	"devDependencies": {
		"@eslint/js": "9.30.1",
		"@types/node": "^20.19.35",
		"@vitest/coverage-v8": "^4.1.8",
		"electron": "^42.4.0",
		"esbuild": "0.25.5",
		"eslint-plugin-obsidianmd": "0.1.9",
		"fake-indexeddb": "^6.2.5",
		"globals": "14.0.0",
		"jiti": "2.6.1",
		"obsidian": "^1.13.1",
		"tslib": "2.4.0",
		"typescript": "^5.8.3",
		"typescript-eslint": "8.35.1",
		"vitest": "^4.0.18"
	},
	"dependencies": {
		"fflate": "^0.8.3",
		"ignore": "^7.0.5",
		"js-md5": "^0.8.3",
		"node-diff3": "^3.2.0"
	}
}

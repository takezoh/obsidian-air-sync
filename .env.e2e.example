# Copy to .env.e2e (gitignored) and fill via the loopback bootstrap:
#   npm run e2e:bootstrap -- google
#   npm run e2e:bootstrap -- dropbox
#   npm run e2e:bootstrap -- onedrive
#   npm run e2e:bootstrap -- pcloud
# Any backend may be omitted — its suite then warns and skips (never fails).
# Use a THROWAWAY test account, not a real vault: the suite creates and deletes
# an `airsync-e2e-*` folder on each run.
#
# One-time OAuth-app setup (see docs/e2e-testing.md):
#  - Google: create your own GCP OAuth client (Desktop, or Web with redirect
#    http://localhost:53682/callback) and put its id/secret below. The built-in
#    auth server can't return tokens to a loopback, so the e2e uses your client.
#  - Dropbox: add http://localhost:53682/callback as a redirect URI on the app.
#  - OneDrive: the shipped client id is a placeholder, so register your own Entra
#    (Azure AD) app — "Personal Microsoft accounts only", Files.ReadWrite.AppFolder,
#    redirect http://localhost:53682/callback — and put its client id below.
#  - pCloud: register an app at https://docs.pcloud.com/ ("My Applications"), add
#    http://localhost:53682/callback as a redirect URI, and put its client id AND
#    secret below. The bootstrap runs the oauth2_token exchange and writes the
#    long-lived access token (no refresh) + region host. Alternative: skip the
#    bootstrap/secret and paste a long-lived access_token by hand (below).
#  - Override the port with AIRSYNC_E2E_OAUTH_PORT (must match the registered URI).

# Google Drive (loopback bootstrap requires your own GCP OAuth client)
AIRSYNC_E2E_GOOGLE_CLIENT_ID=
AIRSYNC_E2E_GOOGLE_CLIENT_SECRET=
AIRSYNC_E2E_GOOGLE_REFRESH_TOKEN=

# Dropbox (public PKCE client; only a loopback redirect URI registration is needed)
AIRSYNC_E2E_DROPBOX_REFRESH_TOKEN=

# OneDrive (requires your own Entra app client id — PKCE, no secret)
AIRSYNC_E2E_ONEDRIVE_CLIENT_ID=
AIRSYNC_E2E_ONEDRIVE_REFRESH_TOKEN=

# pCloud — bootstrap with your own dev OAuth client (id + secret), or paste a
# long-lived access token by hand. The bootstrap fills ACCESS_TOKEN + API_HOST.
AIRSYNC_E2E_PCLOUD_CLIENT_ID=
AIRSYNC_E2E_PCLOUD_CLIENT_SECRET=
AIRSYNC_E2E_PCLOUD_ACCESS_TOKEN=
# EU account? Set eapi.pcloud.com (default api.pcloud.com)
# AIRSYNC_E2E_PCLOUD_API_HOST=eapi.pcloud.com

# Optional: loopback port for the bootstrap (default 53682)
# AIRSYNC_E2E_OAUTH_PORT=53682

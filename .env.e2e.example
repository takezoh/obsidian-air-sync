# Copy to .env.e2e (gitignored) and fill via:
#   npm run e2e:bootstrap -- google
#   npm run e2e:bootstrap -- dropbox
# Either backend may be omitted — its suite then warns and skips (never fails).
# Use a THROWAWAY test account, not a real vault: the suite creates and deletes
# an `airsync-e2e-*` folder on each run.
AIRSYNC_E2E_GOOGLE_REFRESH_TOKEN=
AIRSYNC_E2E_DROPBOX_REFRESH_TOKEN=
